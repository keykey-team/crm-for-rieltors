generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
  output = "../node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id                String                 @id @default(cuid())
  name              String?
  email             String                 @unique
  password          String
  role              String                 @default("agent")
  phone             String?
  avatar            String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  accountType       String                 @default("agent")
  plan              String                 @default("free")
  brandLogo         String?
  brandName         String?
  primaryColor      String?
  calendarToken     String?
  gradientBg        Boolean?               @default(false)
  sidebarGlass      Boolean?               @default(false)
  sidebarOpacity    Float?                 @default(1)
  themeMode         String?                @default("light")
  permissions       String?
  lastAgencyId      String?
  activityLogs      ActivityLog[]          @relation("ActivityLogUser")
  automations       Automation[]           @relation("AutomationCreator")
  mentionedIn       ChatMention[]          @relation("MentionedUser")
  receivedMessages  ChatMessage[]          @relation("ChatReceiver")
  sentMessages      ChatMessage[]          @relation("ChatSender")
  chatRooms         ChatRoomMember[]       @relation("ChatRoomMembership")
  communications    Communication[]        @relation("CommunicationUser")
  deals             Deal[]
  dealComments      DealComment[]          @relation("DealCommentAuthor")
  events            Event[]
  articles          KnowledgeArticle[]
  leads             Lead[]
  agentShowings     Showing[]              @relation("ShowingAgent")
  distributionRules LeadDistributionRule[] @relation("DistributionAssign")
  tasks             Task[]
  templates         Template[]             @relation("TemplateCreator")
  propertyPriceChanges PropertyPriceHistory[] @relation("PropertyPriceChanges")
  createdSelections    ClientSelection[]      @relation("CreatedSelections")
  memberships          AgencyMembership[]     @relation("UserMemberships")
  ownedAgencies        Agency[]               @relation("AgencyOwner")

  helperMessages  HelperMessage[]

  @@index([email])
}

model Agency {
  id             String             @id @default(cuid())
  name           String
  slug           String             @unique
  plan           String             @default("free")
  ownerId        String
  brandLogo      String?
  brandName      String?
  primaryColor   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  owner          User               @relation("AgencyOwner", fields: [ownerId], references: [id])
  memberships    AgencyMembership[]
  leads          Lead[]
  properties     Property[]
  deals          Deal[]
  tasks          Task[]
  events         Event[]
  templates      Template[]
  automations    Automation[]
  funnels        Funnel[]
  chatRooms      ChatRoom[]
  knowledge      KnowledgeArticle[]
  communications Communication[]
  rules          LeadDistributionRule[]
  aftercarePlans AftercarePlan[]
  dictionaries   Dictionary[]
  activityLogs   ActivityLog[]
  showings       Showing[]
  priceHistory   PropertyPriceHistory[]
  selections     ClientSelection[]
  selectionItems SelectionItem[]

  @@index([ownerId])
}

model AgencyMembership {
  id        String   @id @default(cuid())
  agencyId  String
  userId    String
  role      String   @default("agent")
  isActive  Boolean  @default(true)
  invitedBy String?
  joinedAt  DateTime @default(now())
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user      User     @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([userId])
  @@index([agencyId])
}

model Lead {
  id             String          @id @default(cuid())
  firstName      String
  lastName       String?
  email          String?
  phone          String
  source         String          @default("manual")
  status         String          @default("new_lead")
  needType       String          @default("buy")
  budget         Float?
  budgetMax      Float?
  districts      String?
  propertyType   String?
  notes          String?
  priority       String          @default("medium")
  assignedToId   String?
  agencyId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lastContact    DateTime?
  communications Communication[]
  deals          Deal[]
  assignedTo     User?           @relation(fields: [assignedToId], references: [id])
  tasks          Task[]
  showings       Showing[]
  selections     ClientSelection[]
  agency         Agency          @relation(fields: [agencyId], references: [id])

  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([agencyId])
}

model Property {
  id          String          @id @default(cuid())
  title       String
  type        String          @default("apartment")
  address     String
  district    String?
  city        String          @default("Киев")
  rooms       Int?
  area        Float?
  floor       Int?
  totalFloors Int?
  price       Float
  currency    String          @default("USD")
  status      String          @default("active")
  dealTypes   String[]        @default([])
  description String?
  agencyId    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deals       Deal[]
  photos      PropertyPhoto[]
  showings    Showing[]
  units       PropertyUnit[]
  priceHistory   PropertyPriceHistory[]
  selectionItems SelectionItem[]
  agency         Agency          @relation(fields: [agencyId], references: [id])

  @@index([status])
  @@index([type])
  @@index([price])
  @@index([agencyId])
}

model PropertyPriceHistory {
  id         String   @id @default(cuid())
  propertyId String
  agencyId   String
  price      Float
  currency   String
  changedBy  String?
  reason     String?
  note       String?
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agency     Agency   @relation(fields: [agencyId], references: [id])
  user       User?    @relation("PropertyPriceChanges", fields: [changedBy], references: [id])

  @@index([propertyId])
  @@index([agencyId])
  @@index([createdAt])
}

model PropertyPhoto {
  id               String   @id @default(cuid())
  propertyId       String
  cloudStoragePath String
  isPublic         Boolean  @default(true)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Deal {
  id                String                 @id @default(cuid())
  title             String
  stage             String                 @default("new_lead")
  funnelId          String?
  amount            Float?
  commission        Float?
  leadId            String?
  propertyId        String?
  assignedToId      String?
  agencyId          String
  notes             String?
  meetingDate       DateTime?
  showDate          DateTime?
  depositDate       DateTime?
  closeDate         DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  currency          String                 @default("USD")
  funnel            Funnel?                @relation(fields: [funnelId], references: [id])
  assignedTo        User?                  @relation(fields: [assignedToId], references: [id])
  lead              Lead?                  @relation(fields: [leadId], references: [id])
  property          Property?              @relation(fields: [propertyId], references: [id])
  checklist         DealChecklist[]
  comments          DealComment[]
  customFieldValues DealCustomFieldValue[]
  showings          Showing[]
  agency            Agency                 @relation(fields: [agencyId], references: [id])

  @@index([stage])
  @@index([funnelId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([agencyId])
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  type         String    @default("call")
  priority     String    @default("medium")
  status       String    @default("pending")
  dueDate      DateTime?
  completedAt  DateTime?
  leadId       String?
  assignedToId String?
  agencyId     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])
  lead         Lead?     @relation(fields: [leadId], references: [id])
  agency       Agency    @relation(fields: [agencyId], references: [id])

  @@index([status])
  @@index([dueDate])
  @@index([assignedToId])
  @@index([agencyId])
}

model Showing {
  id           String   @id @default(cuid())
  dealId       String?
  propertyId   String
  leadId       String?
  agentId      String?
  agencyId     String
  scheduledAt  DateTime
  durationMin  Int      @default(30)
  status       String   @default("scheduled")
  feedback     String?
  clientRating Int?
  agentNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deal     Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agent    User?    @relation("ShowingAgent", fields: [agentId], references: [id])
  agency   Agency   @relation(fields: [agencyId], references: [id])

  @@index([dealId])
  @@index([propertyId])
  @@index([leadId])
  @@index([agentId])
  @@index([agencyId])
  @@index([scheduledAt])
  @@index([status])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("meeting")
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  userId      String?
  agencyId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id])
  agency      Agency    @relation(fields: [agencyId], references: [id])

  @@index([startDate])
  @@index([userId])
  @@index([agencyId])
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general")
  authorId  String?
  agencyId  String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User?    @relation(fields: [authorId], references: [id])
  agency    Agency   @relation(fields: [agencyId], references: [id])

  @@index([category])
  @@index([agencyId])
}

model Automation {
  id            String    @id @default(cuid())
  name          String
  description   String?
  trigger       String
  triggerValue  String?
  action        String
  actionValue   String?
  isActive      Boolean   @default(true)
  createdById   String?
  agencyId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastRunAt     DateTime?
  lastRunResult String?
  createdBy     User?     @relation("AutomationCreator", fields: [createdById], references: [id])
  agency        Agency    @relation(fields: [agencyId], references: [id])

  @@index([agencyId])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("message")
  category    String   @default("general")
  content     String
  variables   String?
  createdById String?
  agencyId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation("TemplateCreator", fields: [createdById], references: [id])
  agency      Agency   @relation(fields: [agencyId], references: [id])

  @@index([type])
  @@index([category])
  @@index([agencyId])
}

model DealComment {
  id        String   @id @default(cuid())
  dealId    String
  authorId  String?
  text      String
  createdAt DateTime @default(now())
  author    User?    @relation("DealCommentAuthor", fields: [authorId], references: [id])
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model DealChecklist {
  id        String   @id @default(cuid())
  dealId    String
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  details    String?
  userId     String?
  agencyId   String
  createdAt  DateTime @default(now())
  user       User?    @relation("ActivityLogUser", fields: [userId], references: [id])
  agency     Agency   @relation(fields: [agencyId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([agencyId])
}

model PropertyUnit {
  id         String   @id @default(cuid())
  propertyId String
  unitNumber String
  floor      Int
  section    Int      @default(1)
  rooms      Int?
  area       Float?
  price      Float?
  status     String   @default("available")
  dealId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([status])
}

model Funnel {
  id        String        @id @default(cuid())
  name      String
  isDefault Boolean       @default(false)
  isActive  Boolean       @default(true)
  order     Int           @default(0)
  agencyId  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deals     Deal[]
  stages    FunnelStage[]
  agency    Agency        @relation(fields: [agencyId], references: [id])

  @@index([order])
  @@index([agencyId])
}

model FunnelStage {
  id        String   @id @default(cuid())
  funnelId  String?
  funnel    Funnel?  @relation(fields: [funnelId], references: [id])
  value     String   @unique
  label     String
  color     String   @default("#60B5FF")
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([funnelId])
}

model DealCustomField {
  id        String                 @id @default(cuid())
  name      String
  label     String
  fieldType String                 @default("text")
  options   String?
  required  Boolean                @default(false)
  order     Int                    @default(0)
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  values    DealCustomFieldValue[]
}

model DealCustomFieldValue {
  id        String          @id @default(cuid())
  dealId    String
  fieldId   String
  value     String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deal      Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  field     DealCustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([dealId, fieldId])
  @@index([dealId])
  @@index([fieldId])
}

model Communication {
  id        String   @id @default(cuid())
  leadId    String
  type      String   @default("note")
  direction String?
  content   String
  userId    String?
  agencyId  String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation("CommunicationUser", fields: [userId], references: [id])
  agency    Agency   @relation(fields: [agencyId], references: [id])

  @@index([leadId])
  @@index([createdAt])
  @@index([agencyId])
}

model ClientSelection {
  id           String          @id @default(cuid())
  leadId       String
  createdById  String
  agencyId     String
  publicSlug   String          @unique
  title        String?
  message      String?
  expiresAt    DateTime?
  viewsCount   Int             @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lead         Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy    User            @relation("CreatedSelections", fields: [createdById], references: [id])
  agency       Agency          @relation(fields: [agencyId], references: [id])
  items        SelectionItem[]

  @@index([leadId])
  @@index([createdById])
  @@index([agencyId])
  @@index([publicSlug])
}

model SelectionItem {
  id             String          @id @default(cuid())
  selectionId    String
  propertyId     String
  agencyId       String
  order          Int             @default(0)
  agentComment   String?
  clientReaction String?
  clientNote     String?
  reactedAt      DateTime?
  createdAt      DateTime        @default(now())
  selection      ClientSelection @relation(fields: [selectionId], references: [id], onDelete: Cascade)
  property       Property        @relation(fields: [propertyId], references: [id])
  agency         Agency          @relation(fields: [agencyId], references: [id])

  @@unique([selectionId, propertyId])
  @@index([selectionId])
  @@index([agencyId])
}

model AftercarePlan {
  id          String          @id @default(cuid())
  name        String
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  order       Int             @default(0)
  agencyId    String
  steps       AftercareStep[]
  agency      Agency          @relation(fields: [agencyId], references: [id])

  @@index([agencyId])
}

model AftercareStep {
  id        String        @id @default(cuid())
  planId    String
  dayOffset Int
  type      String        @default("message")
  title     String
  content   String?
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  plan      AftercarePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model Dictionary {
  id        String   @id @default(cuid())
  category  String
  value     String
  label     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  agencyId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agency    Agency   @relation(fields: [agencyId], references: [id])

  @@unique([agencyId, category, value])
  @@index([category])
  @@index([agencyId])
}

model ChatMessage {
  id         String        @id @default(cuid())
  senderId   String
  receiverId String
  text       String
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  roomId     String?
  threadId   String?
  mentions   ChatMention[] @relation("MessageMentions")
  receiver   User          @relation("ChatReceiver", fields: [receiverId], references: [id])
  room       ChatRoom?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender     User          @relation("ChatSender", fields: [senderId], references: [id])
  thread     ChatMessage?  @relation("ThreadReplies", fields: [threadId], references: [id])
  replies    ChatMessage[] @relation("ThreadReplies")

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
  @@index([createdAt])
  @@index([roomId])
  @@index([threadId])
}

model ChatRoom {
  id          String           @id @default(cuid())
  name        String?
  type        String           @default("direct")
  createdById String?
  agencyId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  messages    ChatMessage[]
  members     ChatRoomMember[]
  agency      Agency           @relation(fields: [agencyId], references: [id])

  @@index([type])
  @@index([agencyId])
}

model ChatRoomMember {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation("ChatRoomMembership", fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMention {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation("MessageMentions", fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation("MentionedUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([messageId])
}

model LeadDistributionRule {
  id           String   @id @default(cuid())
  name         String
  source       String?
  district     String?
  propertyType String?
  needType     String?
  assignToId   String
  agencyId     String
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignTo     User     @relation("DistributionAssign", fields: [assignToId], references: [id])
  agency       Agency   @relation(fields: [agencyId], references: [id])

  @@index([isActive])
  @@index([agencyId])
}

model HelperMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
