REPO_URL=git@github.com:your-org/your-repo.git
BRANCH=develop

APP_NAME=realcrm
APP_USER=ubuntu
APP_HOME=/home/ubuntu
PROJECT_NAME=realtor_crm
APP_PORT=3000

DOMAIN=crm.example.com
APP_SCHEME=https
CLIENT_MAX_BODY_SIZE=25M

ENABLE_CERTBOT=0
LETSENCRYPT_EMAIL=admin@example.com
ENABLE_FIREWALL=1
INSTALL_AWS_CLI=0

POSTGRES_DB=realcrm_db
POSTGRES_USER=realcrm_user
POSTGRES_PASSWORD=change_me_db_password

RUN_SEED=1

NEXTAUTH_SECRET=
AUTOMATION_SECRET=

AWS_REGION=
AWS_BUCKET_NAME=
AWS_FOLDER_PREFIX=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=